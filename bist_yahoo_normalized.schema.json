{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/bist-yahoo-normalized.schema.json",
  "title": "BIST Yahoo Normalized Market Data",
  "description": "Yahoo Finance kaynaklı (delayed) BIST verisini simülasyon platformunda standartlaştırmak için normalize şema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider",
    "market",
    "symbol",
    "delayed",
    "currency",
    "asOfTs",
    "quote",
    "candles",
    "meta",
    "quality"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "const": "yahoo"
    },
    "market": {
      "type": "string",
      "const": "BIST"
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9^.-]+\\.IS$",
      "examples": [
        "THYAO.IS",
        "ASELS.IS",
        "XU100.IS"
      ]
    },
    "delayed": {
      "type": "boolean",
      "const": true
    },
    "currency": {
      "type": "string",
      "examples": [
        "TRY"
      ]
    },
    "asOfTs": {
      "type": "integer",
      "description": "Verinin platforma yazıldığı Unix epoch saniyesi",
      "minimum": 0
    },
    "quote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last",
        "previousClose",
        "dayChange",
        "dayChangePct",
        "marketTime"
      ],
      "properties": {
        "last": {
          "type": "number"
        },
        "previousClose": {
          "type": "number"
        },
        "dayChange": {
          "type": "number",
          "description": "last - previousClose"
        },
        "dayChangePct": {
          "type": "number",
          "description": "(last - previousClose) / previousClose * 100"
        },
        "dayLow": {
          "type": [
            "number",
            "null"
          ]
        },
        "dayHigh": {
          "type": [
            "number",
            "null"
          ]
        },
        "fiftyTwoWeekLow": {
          "type": [
            "number",
            "null"
          ]
        },
        "fiftyTwoWeekHigh": {
          "type": [
            "number",
            "null"
          ]
        },
        "regularVolume": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "avgVolume": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "marketTime": {
          "type": "integer",
          "description": "Yahoo regularMarketTime (epoch saniye)",
          "minimum": 0
        }
      }
    },
    "candles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ts",
          "interval",
          "open",
          "high",
          "low",
          "close",
          "volume",
          "isComplete"
        ],
        "properties": {
          "ts": {
            "type": "integer",
            "minimum": 0
          },
          "interval": {
            "type": "string",
            "enum": [
              "1m",
              "2m",
              "5m",
              "15m",
              "30m",
              "60m",
              "1d",
              "1wk",
              "1mo"
            ]
          },
          "open": {
            "type": "number"
          },
          "high": {
            "type": "number"
          },
          "low": {
            "type": "number"
          },
          "close": {
            "type": "number"
          },
          "volume": {
            "type": "integer",
            "minimum": 0
          },
          "isComplete": {
            "type": "boolean",
            "description": "Kapanmış mum ise true, devam eden mum ise false"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "open": {
                  "type": "number"
                },
                "close": {
                  "type": "number"
                },
                "high": {
                  "type": "number"
                },
                "low": {
                  "type": "number"
                }
              }
            },
            "then": {
              "description": "İş kuralı: low <= min(open, close) ve high >= max(open, close) kontrolü uygulama katmanında ayrıca yapılmalı"
            }
          }
        ]
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dividends": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ts",
              "amount"
            ],
            "properties": {
              "ts": {
                "type": "integer",
                "minimum": 0
              },
              "amount": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "splits": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ts",
              "numerator",
              "denominator"
            ],
            "properties": {
              "ts": {
                "type": "integer",
                "minimum": 0
              },
              "numerator": {
                "type": "integer",
                "minimum": 1
              },
              "denominator": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exchangeName",
        "fullExchangeName",
        "timezone",
        "gmtoffset",
        "dataGranularity",
        "range"
      ],
      "properties": {
        "exchangeName": {
          "type": "string",
          "examples": [
            "IST"
          ]
        },
        "fullExchangeName": {
          "type": "string",
          "examples": [
            "Istanbul"
          ]
        },
        "timezone": {
          "type": "string",
          "examples": [
            "TRT"
          ]
        },
        "gmtoffset": {
          "type": "integer"
        },
        "dataGranularity": {
          "type": "string",
          "examples": [
            "5m"
          ]
        },
        "range": {
          "type": "string",
          "examples": [
            "1d",
            "5d",
            "1mo"
          ]
        },
        "marketState": {
          "type": [
            "string",
            "null"
          ],
          "examples": [
            "REGULAR"
          ]
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "staleSec",
        "ohlcConsistent",
        "warnings"
      ],
      "properties": {
        "staleSec": {
          "type": "integer",
          "minimum": 0,
          "description": "now - quote.marketTime"
        },
        "ohlcConsistent": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
